<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:text="@string/configure_title"/>

        <Button
            android:id="@+id/btn_use_global"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/use_global_defaults"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:text="@string/customize"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_style"/>
        <Spinner
            android:id="@+id/spinner_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <CheckBox
            android:id="@+id/check_inherit_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inherit_global"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_actions_mode"/>
        <Spinner
            android:id="@+id/spinner_actions_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <CheckBox
            android:id="@+id/check_inherit_actions_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inherit_global"/>

        <CheckBox
            android:id="@+id/check_allow_raw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_allow_raw"/>
        <CheckBox
            android:id="@+id/check_inherit_allow_raw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inherit_global"/>

        <CheckBox
            android:id="@+id/check_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_progress"/>
        <CheckBox
            android:id="@+id/check_inherit_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inherit_global"/>

        <CheckBox
            android:id="@+id/check_cover_tap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/setting_cover_tap"/>
        <CheckBox
            android:id="@+id/check_inherit_cover_tap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inherit_global"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">
            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cancel"/>
            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/save"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
