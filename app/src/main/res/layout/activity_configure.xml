<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/configure_title"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingTop="32dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/configure_subtitle"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:paddingBottom="20dp"/>

        <!-- Quick: Use Global Defaults -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/use_global_defaults"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/use_global_defaults_help"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:lineSpacingMultiplier="1.25"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_use_global"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/use_global_apply"
                    app:cornerRadius="14dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Individual settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline"
            app:cardBackgroundColor="?attr/colorSurface"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/customize"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/customize_subtitle"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp"
                    android:lineSpacingMultiplier="1.25"/>

                <!-- Style -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_style"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="22dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_style_help"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.25"/>
                <Spinner
                    android:id="@+id/spinner_style"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"/>
                <CheckBox
                    android:id="@+id/check_inherit_style"
                    style="@style/InheritCheck"
                    android:text="@string/inherit_global"/>

                <!-- App Actions Mode -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_actions_mode"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="18dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_actions_mode_help"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.25"/>
                <Spinner
                    android:id="@+id/spinner_actions_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"/>
                <CheckBox
                    android:id="@+id/check_inherit_actions_mode"
                    style="@style/InheritCheck"
                    android:text="@string/inherit_global"/>

                <!-- Allow Raw -->
                <LinearLayout style="@style/SwitchRow" android:layout_marginTop="18dp">
                    <LinearLayout style="@style/SwitchRowLabelCol">
                        <TextView style="@style/SwitchRowLabel" android:text="@string/setting_allow_raw"/>
                        <TextView style="@style/SwitchRowHelp" android:text="@string/setting_allow_raw_help"/>
                    </LinearLayout>
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/check_allow_raw"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <CheckBox
                    android:id="@+id/check_inherit_allow_raw"
                    style="@style/InheritCheck"
                    android:text="@string/inherit_global"/>

                <!-- Progress -->
                <LinearLayout style="@style/SwitchRow" android:layout_marginTop="14dp">
                    <LinearLayout style="@style/SwitchRowLabelCol">
                        <TextView style="@style/SwitchRowLabel" android:text="@string/setting_progress"/>
                        <TextView style="@style/SwitchRowHelp" android:text="@string/setting_progress_help"/>
                    </LinearLayout>
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/check_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <CheckBox
                    android:id="@+id/check_inherit_progress"
                    style="@style/InheritCheck"
                    android:text="@string/inherit_global"/>

                <!-- Cover Tap -->
                <LinearLayout style="@style/SwitchRow" android:layout_marginTop="14dp">
                    <LinearLayout style="@style/SwitchRowLabelCol">
                        <TextView style="@style/SwitchRowLabel" android:text="@string/setting_cover_tap"/>
                        <TextView style="@style/SwitchRowHelp" android:text="@string/setting_cover_tap_help"/>
                    </LinearLayout>
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/check_cover_tap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <CheckBox
                    android:id="@+id/check_inherit_cover_tap"
                    style="@style/InheritCheck"
                    android:text="@string/inherit_global"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cancel"
                app:cornerRadius="14dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/save"
                app:cornerRadius="14dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
