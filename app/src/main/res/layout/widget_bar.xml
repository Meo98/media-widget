<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background">

    <ImageView
        android:id="@+id/cover"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:background="@drawable/widget_cover_background"
        android:src="@drawable/ic_music"
        android:contentDescription="@string/cover_desc"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/idle_title"/>
        <TextView
            android:id="@+id/artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/idle_artist"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_prev"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_prev"
        android:contentDescription="@string/prev_desc"/>
    <ImageButton
        android:id="@+id/btn_play_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_play"
        android:contentDescription="@string/play_pause_desc"/>
    <ImageButton
        android:id="@+id/btn_next"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_next"
        android:contentDescription="@string/next_desc"/>

    <ImageButton
        android:id="@+id/action_slot_1"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="6dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_heart"
        android:visibility="gone"
        android:contentDescription="@string/action_slot_desc"/>

    <LinearLayout
        android:id="@+id/app_switcher_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/app_switcher_1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@string/app_switcher_desc"/>
        <ImageView
            android:id="@+id/app_switcher_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="3dp"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@string/app_switcher_desc"/>
        <ImageView
            android:id="@+id/app_switcher_3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="3dp"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@string/app_switcher_desc"/>
    </LinearLayout>
</LinearLayout>
